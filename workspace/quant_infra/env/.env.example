# OpenBB Provider API Keys (optional — yfinance works without keys)
# OPENBB_FMP_API_KEY=your_fmp_key
# OPENBB_TIINGO_API_KEY=your_tiingo_key
# OPENBB_BENZINGA_API_KEY=your_benzinga_key
# OPENBB_INTRINIO_API_KEY=your_intrinio_key

# DuckDB warehouse path (default: workspace/quant_infra/warehouse/quant.duckdb)
# QUANT_WAREHOUSE_PATH=/custom/path/quant.duckdb

# Data directory (default: ~/.openclaw/workspace/data)
# QUANT_DATA_DIR=/custom/data/path

# OpenBB venv python (default: workspace/quant_infra/env/.venv-openbb/bin/python3)
# OPENBB_PYTHON=/custom/venv/bin/python3
