# =========================
# Jarvis v5 root paths
# =========================
JARVIS_V5_ROOT=/home/rollan/.openclaw/workspace/jarvis-v5
JARVIS_WORKSPACE=/home/rollan/.openclaw/workspace
JARVIS_STATE_DIR=/home/rollan/.openclaw/workspace/jarvis-v5/state
JARVIS_ARTIFACT_DIR=/home/rollan/.openclaw/workspace/jarvis-v5/state/artifacts
JARVIS_LOG_DIR=/home/rollan/.openclaw/workspace/jarvis-v5/state/logs

# =========================
# Discord
# =========================
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_JARVIS=
DISCORD_CHANNEL_TASKS=
DISCORD_CHANNEL_OUTPUTS=
DISCORD_CHANNEL_REVIEW=
DISCORD_CHANNEL_AUDIT=
DISCORD_CHANNEL_CODE_REVIEW=
DISCORD_CHANNEL_FLOWSTATE=

# =========================
# Qwen 3.5 model endpoints
# Qwen-only runtime
# =========================
QWEN_ROUTER_BASE_URL=http://127.0.0.1:1234/v1
QWEN_ROUTER_API_KEY=lm-studio
QWEN_ROUTER_MODEL=Qwen3.5-9B

QWEN_WORKER_BASE_URL=http://127.0.0.1:1234/v1
QWEN_WORKER_API_KEY=lm-studio
QWEN_WORKER_MODEL=Qwen3.5-35B

QWEN_REVIEWER_BASE_URL=http://127.0.0.1:1234/v1
QWEN_REVIEWER_API_KEY=lm-studio
QWEN_REVIEWER_MODEL=Qwen3.5-35B

QWEN_AUDITOR_BASE_URL=http://127.0.0.1:1234/v1
QWEN_AUDITOR_API_KEY=lm-studio
QWEN_AUDITOR_MODEL=Qwen3.5-122B

# Optional external OpenAI-compatible providers
NVIDIA_API_KEY=

# =========================
# Runtime toggles
# =========================
JARVIS_ENABLE_HEARTBEAT=true
JARVIS_ENABLE_FLOWSTATE=true
JARVIS_ENABLE_DASHBOARD=true
JARVIS_VALIDATE_FIRST=true
JARVIS_FAIL_ON_VALIDATION_ERROR=true

# =========================
# Approval / safety toggles
# =========================
JARVIS_REQUIRE_APPROVAL_FOR_CODE=true
JARVIS_REQUIRE_APPROVAL_FOR_FLOWSTATE_PROMOTION=true
JARVIS_REQUIRE_APPROVAL_FOR_DEPLOY=true
JARVIS_REQUIRE_APPROVAL_FOR_QUANT=true
