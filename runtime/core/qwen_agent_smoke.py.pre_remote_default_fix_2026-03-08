def main() -> int:
    if any(arg in {"-h", "--help"} for arg in sys.argv[1:]):
        print("usage: qwen_agent_smoke.py [-h]\n\nInteractive Qwen-Agent Jarvis smoke runner.\n\noptions:\n  -h, --help  show this help message and exit")
        return 0

    bot = build_bot()
    print("Qwen-Agent Jarvis smoke runner")
    print(f"Workspace   : {WORKSPACE}")
    print(f"Model server: {MODEL_SERVER}")
    print(f"Model       : {MODEL_NAME}")
    print(f"Thinking    : {'on' if ENABLE_THINKING else 'off'}")
    print(f"Raw API     : {'on' if USE_RAW_API else 'off'}")
    print("Type 'exit' to quit.\n")

    messages = []
    while True:
        try:
            query = input("user> ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            return 0

        if not query:
            continue
        if query.lower() in {"exit", "quit"}:
            return 0

        messages.append({"role": "user", "content": query})
        response = []
        print("agent>")
        try:
            for chunk in bot.run(messages=messages):
                response = chunk
        except Exception as e:
            print(f"\n[ERROR] {e}")
            continue

        printed = False
        if isinstance(response, list):
            for msg in response:
                if isinstance(msg, dict) and msg.get("role") == "assistant":
                    content = msg.get("content", "")
                    if isinstance(content, str):
                        content = _strip_think_blocks(content)
                        if content:
                            print(content)
                            printed = True
            messages.extend(response)
        else:
            content = _strip_think_blocks(str(response))
            if content:
                print(content)
                printed = True

        if not printed:
            print("(no assistant text)")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
