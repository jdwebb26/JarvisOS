def _safe_path(rel_or_abs: str) -> Path:
    p = Path(rel_or_abs)
    candidate = p if p.is_absolute() else (WORKSPACE / p)
    candidate = candidate.resolve()
    if WORKSPACE not in candidate.parents and candidate != WORKSPACE:
        raise ValueError(f"Path escapes workspace: {candidate}")
    return candidate


def _strip_think_blocks(text: str) -> str:
    return re.sub(r"<think>.*?</think>\s*", "", text, flags=re.DOTALL).strip()


def _should_skip_dir(path: Path) -> bool:
    try:
        parts = path.resolve().relative_to(WORKSPACE).parts
    except Exception:
        return False
    return any(part in SKIP_DIR_NAMES or part in SKIP_DIR_PARTS for part in parts)


def _should_skip_file(path: Path) -> bool:
    try:
        parts = path.resolve().relative_to(WORKSPACE).parts
    except Exception:
        return False
    if any(part in SKIP_DIR_NAMES or part in SKIP_DIR_PARTS for part in parts):
        return True
    if path.suffix.lower() in SKIP_FILE_SUFFIXES:
        return True
    try:
        if path.stat().st_size > 500_000:
            return True
    except Exception:
        return True
    return False


def _scope_decision(task: dict) -> dict:
    title = str(task.get("title", "") or "").lower()
    status = str(task.get("status", "") or "").lower()
    priority = task.get("priority", 0)
    kind = str(task.get("kind", "") or "").lower()
    notes = str(task.get("notes", "") or "").lower()
    payload_path = str(task.get("payload_path", "") or "").strip()

    reasons = []
    allowed = True

    positive_signals = []
    if "strategy factory" in title or "nq sf" in title:
        positive_signals.append("strategy-factory workflow")
    if any(tok in title for tok in ["p1.", "p2.", "phase", "step"]):
        positive_signals.append("structured phase/step naming")
    if any(tok in title for tok in ["implement", "build", "create"]):
        positive_signals.append("implementation-oriented title")

    has_impl_shape = len(positive_signals) >= 2

    if status and status not in {"pending", "running", "done", "completed"}:
        allowed = False
        reasons.append(f"unexpected status={status}")

    if priority is not None:
        try:
            if int(priority) < 5:
                allowed = False
                reasons.append(f"priority too low ({priority})")
        except Exception:
            reasons.append(f"non-integer priority={priority}")

    if "helper" in title or "stub" in notes:
        allowed = False
        reasons.append("generic helper/stub task")

    if "smoke test" in title and not has_impl_shape:
        allowed = False
        reasons.append("generic smoke test without strong implementation signals")

    if not positive_signals:
        allowed = False
        reasons.append("missing structured implementation signals")

    if not payload_path:
        reasons.append("no payload_path present")

    if kind and kind not in {"prompt", "plan", "task", "strategy_factory"}:
        reasons.append(f"unrecognized kind={kind}")

    return {
        "allowed": allowed,
        "positive_signals": positive_signals,
        "reasons": reasons,
    }


@register_tool("workspace_list_files")
class WorkspaceListFiles(BaseTool):
    description = "List files under the Jarvis workspace with pruning for irrelevant directories and large binary files."
    parameters = [
        {"name": "path", "type": "string", "description": "Optional subdirectory path inside the workspace.", "required": False},
        {"name": "pattern", "type": "string", "description": "Optional glob pattern like *.py or *.md.", "required": False},
        {"name": "max_depth", "type": "integer", "description": "Maximum directory depth from the base path.", "required": False},
        {"name": "max_files", "type": "integer", "description": "Maximum number of files to return.", "required": False},
    ]

    def call(self, params: str, **kwargs) -> str:
        data = _json_parser.loads(params or "{}")
        sub = data.get("path", "")
        pattern = data.get("pattern", "*")
        max_depth = int(data.get("max_depth", 4))
        max_files = int(data.get("max_files", 200))

        base = _safe_path(sub) if sub else WORKSPACE
        if not base.exists():
            return json.dumps({"error": f"Not found: {base}"}, indent=2)

        if base.is_file():
            return json.dumps(
                {
                    "workspace": str(WORKSPACE),
                    "files": [{"path": str(base.relative_to(WORKSPACE)), "bytes": base.stat().st_size}],
                },
                indent=2,
            )

        files = []
        base_depth = len(base.relative_to(WORKSPACE).parts)

        for root, dirs, names in os.walk(base):
            root_path = Path(root)
            rel_depth = len(root_path.relative_to(WORKSPACE).parts) - base_depth

            dirs[:] = [
                d for d in dirs
                if not _should_skip_dir(root_path / d) and rel_depth < max_depth
            ]

            for name in sorted(names):
                f = root_path / name
                if _should_skip_file(f):
                    continue
                rel_str = str(f.relative_to(WORKSPACE))
                if not fnmatch.fnmatch(name, pattern) and not fnmatch.fnmatch(rel_str, pattern):
                    continue

                files.append({"path": rel_str, "bytes": f.stat().st_size})
                if len(files) >= max_files:
                    return json.dumps(
                        {
                            "workspace": str(WORKSPACE),
                            "base": str(base.relative_to(WORKSPACE)) if base != WORKSPACE else ".",
                            "pattern": pattern,
                            "max_depth": max_depth,
                            "truncated": True,
                            "files": files,
                        },
                        indent=2,
                        ensure_ascii=False,
                    )

        return json.dumps(
            {
                "workspace": str(WORKSPACE),
                "base": str(base.relative_to(WORKSPACE)) if base != WORKSPACE else ".",
                "pattern": pattern,
                "max_depth": max_depth,
                "truncated": False,
                "files": files,
            },
            indent=2,
            ensure_ascii=False,
        )


@register_tool("workspace_read_file")
class WorkspaceReadFile(BaseTool):
    description = "Read a UTF-8 text file inside the Jarvis workspace."
    parameters = [
        {"name": "path", "type": "string", "description": "File path inside the workspace.", "required": True}
    ]

    def call(self, params: str, **kwargs) -> str:
        data = _json_parser.loads(params or "{}")
        path = _safe_path(data["path"])
        if not path.exists() or not path.is_file():
            return json.dumps({"error": f"File not found: {path}"}, indent=2)
        text = path.read_text(encoding="utf-8", errors="replace")
        return json.dumps(
            {
                "path": str(path.relative_to(WORKSPACE)),
                "content": text[:MAX_READ_CHARS],
                "truncated": len(text) > MAX_READ_CHARS,
                "total_chars": len(text),
            },
            indent=2,
            ensure_ascii=False,
        )


@register_tool("workspace_write_file")
class WorkspaceWriteFile(BaseTool):
    description = "Write a UTF-8 text file inside the Jarvis workspace. Use only for clearly requested edits or new files."
    parameters = [
        {"name": "path", "type": "string", "description": "File path inside the workspace.", "required": True},
        {"name": "content", "type": "string", "description": "Full file content to write.", "required": True},
    ]

    def call(self, params: str, **kwargs) -> str:
        data = _json_parser.loads(params or "{}")
        path = _safe_path(data["path"])
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(data["content"], encoding="utf-8")
        return json.dumps(
            {"ok": True, "path": str(path.relative_to(WORKSPACE)), "bytes": path.stat().st_size},
            indent=2,
            ensure_ascii=False,
        )


@register_tool("workspace_recent_tasks")
class WorkspaceRecentTasks(BaseTool):
    description = "Read the most recent tasks from the workspace task database without modifying anything."
    parameters = [
        {"name": "limit", "type": "integer", "description": "Maximum number of recent tasks to return. Default 10.", "required": False}
    ]

    def call(self, params: str, **kwargs) -> str:
        data = _json_parser.loads(params or "{}")
        limit = int(data.get("limit", 10))
        limit = max(1, min(limit, 25))

        if not TASK_DB.exists():
            return json.dumps({"error": f"Database not found: {TASK_DB}"}, indent=2)

        conn = sqlite3.connect(str(TASK_DB))
        conn.row_factory = sqlite3.Row
        try:
            tables = {
                r["name"]
                for r in conn.execute("SELECT name FROM sqlite_master WHERE type='table'").fetchall()
            }
            if "tasks" not in tables:
                return json.dumps({"error": "No 'tasks' table found in database."}, indent=2)

            pragma_rows = conn.execute("PRAGMA table_info(tasks)").fetchall()
            cols = [r["name"] if "name" in r.keys() else r[1] for r in pragma_rows]

            wanted = ["id", "title", "status", "priority", "created_at"]
            selected = [c for c in wanted if c in cols]
            if not selected:
                return json.dumps(
                    {"error": "Expected task columns not found.", "available_columns": cols},
                    indent=2,
                    ensure_ascii=False,
                )

            order_col = "created_at" if "created_at" in cols else ("updated_at" if "updated_at" in cols else "id")
            sql = f"SELECT {', '.join(selected)} FROM tasks ORDER BY {order_col} DESC LIMIT ?"
            rows = conn.execute(sql, (limit,)).fetchall()

            out = []
            for row in rows:
                item = {}
                for col in selected:
                    val = row[col]
                    if col == "title" and val is not None:
                        val = str(val).replace("\n", " ").strip()
                        if len(val) > 140:
                            val = val[:137] + "..."
                    item[col] = val
                out.append(item)

            return json.dumps(
                {"db": str(TASK_DB), "count": len(out), "tasks": out},
                indent=2,
                ensure_ascii=False,
            )
        finally:
            conn.close()


@register_tool("workspace_recent_results")
class WorkspaceRecentResults(BaseTool):
    description = "Read the most recent markdown result artifacts from the workspace results directory without modifying anything."
    parameters = [
        {"name": "limit", "type": "integer", "description": "Maximum number of recent result files to return. Default 5.", "required": False}
    ]

    def call(self, params: str, **kwargs) -> str:
        data = _json_parser.loads(params or "{}")
        limit = int(data.get("limit", 5))
        limit = max(1, min(limit, 10))

        if not RESULTS_DIR.exists():
            return json.dumps({"error": f"Results directory not found: {RESULTS_DIR}"}, indent=2)

        files = sorted(
            [p for p in RESULTS_DIR.glob("*.md") if p.is_file()],
            key=lambda p: p.stat().st_mtime,
            reverse=True,
        )[:limit]

        out = []
        for p in files:
            text = p.read_text(encoding="utf-8", errors="replace")
            out.append(
                {
                    "path": str(p.relative_to(WORKSPACE)),
                    "bytes": p.stat().st_size,
                    "preview": text[:1200],
                    "truncated": len(text) > 1200,
                }
            )

        return json.dumps(
            {
                "results_dir": str(RESULTS_DIR),
                "count": len(out),
                "results": out,
            },
            indent=2,
            ensure_ascii=False,
        )


@register_tool("workspace_get_task_by_id")
class WorkspaceGetTaskById(BaseTool):
    description = "Read one specific task record from the workspace task database by task id without modifying anything."
    parameters = [
        {"name": "task_id", "type": "integer", "description": "Task id to fetch.", "required": True}
    ]

    def call(self, params: str, **kwargs) -> str:
        data = _json_parser.loads(params or "{}")
        task_id = int(data["task_id"])

        if not TASK_DB.exists():
            return json.dumps({"error": f"Database not found: {TASK_DB}"}, indent=2)

        conn = sqlite3.connect(str(TASK_DB))
        conn.row_factory = sqlite3.Row
        try:
            row = conn.execute("SELECT * FROM tasks WHERE id = ?", (task_id,)).fetchone()
            if row is None:
                return json.dumps({"error": f"Task not found: {task_id}"}, indent=2)

            item = {}
            for col in row.keys():
                val = row[col]
                if isinstance(val, str):
                    val = val.replace("\r\n", "\n")
                    if len(val) > 4000:
                        val = val[:4000] + "\n...[truncated]"
                item[col] = val

            return json.dumps(
                {
                    "db": str(TASK_DB),
                    "task_id": task_id,
                    "task": item,
                },
                indent=2,
                ensure_ascii=False,
            )
        finally:
            conn.close()


