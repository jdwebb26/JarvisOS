@register_tool("workspace_scope_check")
class WorkspaceScopeCheck(BaseTool):
    description = "Check whether a specific task is inside the strict initial Qwen scope, read-only."
    parameters = [
        {"name": "task_id", "type": "integer", "description": "Task id to evaluate.", "required": True}
    ]

    def call(self, params: str, **kwargs) -> str:
        data = _json_parser.loads(params or "{}")
        task_id = int(data["task_id"])

        if not TASK_DB.exists():
            return json.dumps({"error": f"Database not found: {TASK_DB}"}, indent=2)

        conn = sqlite3.connect(str(TASK_DB))
        conn.row_factory = sqlite3.Row
        try:
            row = conn.execute("SELECT * FROM tasks WHERE id = ?", (task_id,)).fetchone()
            if row is None:
                return json.dumps({"error": f"Task not found: {task_id}"}, indent=2)

            task = {col: row[col] for col in row.keys()}
            decision = _scope_decision(task)

            summary = {
                "task_id": task_id,
                "title": task.get("title"),
                "status": task.get("status"),
                "priority": task.get("priority"),
                "kind": task.get("kind"),
                "payload_path": task.get("payload_path"),
                "allowed": decision["allowed"],
                "positive_signals": decision["positive_signals"],
                "reasons": decision["reasons"],
            }
            return json.dumps(summary, indent=2, ensure_ascii=False)
        finally:
            conn.close()


@register_tool("workspace_scope_candidates")
class WorkspaceScopeCandidates(BaseTool):
    description = "Scan recent tasks and return which ones are in scope for the initial Qwen lane, read-only."
    parameters = [
        {"name": "limit", "type": "integer", "description": "How many recent tasks to scan. Default 20.", "required": False}
    ]

    def call(self, params: str, **kwargs) -> str:
        data = _json_parser.loads(params or "{}")
        limit = int(data.get("limit", 20))
        limit = max(1, min(limit, 50))

        if not TASK_DB.exists():
            return json.dumps({"error": f"Database not found: {TASK_DB}"}, indent=2)

        conn = sqlite3.connect(str(TASK_DB))
        conn.row_factory = sqlite3.Row
        try:
            tables = {
                r["name"]
                for r in conn.execute("SELECT name FROM sqlite_master WHERE type='table'").fetchall()
            }
            if "tasks" not in tables:
                return json.dumps({"error": "No 'tasks' table found in database."}, indent=2)

            pragma_rows = conn.execute("PRAGMA table_info(tasks)").fetchall()
            cols = [r["name"] if "name" in r.keys() else r[1] for r in pragma_rows]

            order_col = "created_at" if "created_at" in cols else ("updated_at" if "updated_at" in cols else "id")
            rows = conn.execute(f"SELECT * FROM tasks ORDER BY {order_col} DESC LIMIT ?", (limit,)).fetchall()

            allowed = []
            rejected = []

            for row in rows:
                task = {col: row[col] for col in row.keys()}
                decision = _scope_decision(task)

                item = {
                    "task_id": task.get("id"),
                    "title": task.get("title"),
                    "status": task.get("status"),
                    "priority": task.get("priority"),
                    "kind": task.get("kind"),
                    "allowed": decision["allowed"],
                    "positive_signals": decision["positive_signals"],
                    "reasons": decision["reasons"],
                }

                if decision["allowed"]:
                    allowed.append(item)
                else:
                    rejected.append(item)

            return json.dumps(
                {
                    "db": str(TASK_DB),
                    "scanned": len(rows),
                    "allowed_count": len(allowed),
                    "rejected_count": len(rejected),
                    "allowed_tasks": allowed,
                    "rejected_tasks": rejected,
                },
                indent=2,
                ensure_ascii=False,
            )
        finally:
            conn.close()


@register_tool("workspace_review_bundle")
class WorkspaceReviewBundle(BaseTool):
    description = "Return a read-only review bundle for one task id: task row, result artifact, and scope decision."
    parameters = [
        {"name": "task_id", "type": "integer", "description": "Task id to review.", "required": True}
    ]

    def call(self, params: str, **kwargs) -> str:
        data = _json_parser.loads(params or "{}")
        task_id = int(data["task_id"])

        if not TASK_DB.exists():
            return json.dumps({"error": f"Database not found: {TASK_DB}"}, indent=2)

        conn = sqlite3.connect(str(TASK_DB))
        conn.row_factory = sqlite3.Row
        try:
            row = conn.execute("SELECT * FROM tasks WHERE id = ?", (task_id,)).fetchone()
            if row is None:
                return json.dumps({"error": f"Task not found: {task_id}"}, indent=2)

            task = {col: row[col] for col in row.keys()}
            scope = _scope_decision(task)

            result_path = RESULTS_DIR / f"{task_id}.md"
            if result_path.exists() and result_path.is_file():
                text = result_path.read_text(encoding="utf-8", errors="replace")
                result_obj = {
                    "path": str(result_path.relative_to(WORKSPACE)),
                    "content": text[:MAX_READ_CHARS],
                    "truncated": len(text) > MAX_READ_CHARS,
                    "total_chars": len(text),
                }
            else:
                result_obj = {
                    "error": f"Result file not found for task id {task_id}",
                    "path": str(result_path),
                }

            task_out = {}
            for col, val in task.items():
                if isinstance(val, str):
                    val = val.replace("\r\n", "\n")
                    if len(val) > 4000:
                        val = val[:4000] + "\n...[truncated]"
                task_out[col] = val

            return json.dumps(
                {
                    "task_id": task_id,
                    "task": task_out,
                    "scope": scope,
                    "result": result_obj,
                },
                indent=2,
                ensure_ascii=False,
            )
        finally:
            conn.close()


