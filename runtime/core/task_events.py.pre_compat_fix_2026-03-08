#!/usr/bin/env python3
from __future__ import annotations

import json
import sys
from pathlib import Path
from typing import Optional

ROOT = Path(__file__).resolve().parents[2]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from runtime.core.models import TaskEventRecord, new_id, now_iso


def project_root_from_here() -> Path:
    return ROOT


def state_events_dir(root: Optional[Path] = None) -> Path:
    base = Path(root or project_root_from_here()).resolve()
    path = base / "state" / "events"
    path.mkdir(parents=True, exist_ok=True)
    return path


def event_path(event_id: str, root: Optional[Path] = None) -> Path:
    return state_events_dir(root) / f"{event_id}.json"


def append_event(event: TaskEventRecord, root: Optional[Path] = None) -> TaskEventRecord:
    path = event_path(event.event_id, root)
    path.write_text(json.dumps(event.to_dict(), indent=2) + "\n", encoding="utf-8")
    return event


def make_event(
    *,
    task_id: str,
    event_type: str,
    actor: str,
    lane: str,
    summary: Optional[str] = None,
    from_status: Optional[str] = None,
    to_status: Optional[str] = None,
    checkpoint_summary: Optional[str] = None,
    reason: Optional[str] = None,
    final_outcome: Optional[str] = None,
    artifact_id: Optional[str] = None,
    artifact_type: Optional[str] = None,
    artifact_title: Optional[str] = None,
    already_linked: Optional[bool] = None,
    error: str = "",
) -> TaskEventRecord:
    if error and not reason:
        reason = error

    return TaskEventRecord(
        event_id=new_id("evt"),
        task_id=task_id,
        event_type=event_type,
        actor=actor,
        lane=lane,
        created_at=now_iso(),
        from_status=from_status,
        to_status=to_status,
        checkpoint_summary=checkpoint_summary or summary,
        reason=reason,
        final_outcome=final_outcome,
        artifact_id=artifact_id,
        artifact_type=artifact_type,
        artifact_title=artifact_title,
        already_linked=already_linked,
        version="v1",
    )


def list_events(task_id: str, root: Optional[Path] = None, limit: int = 50) -> list[TaskEventRecord]:
    events_dir = state_events_dir(root)
    items: list[TaskEventRecord] = []

    for path in events_dir.glob("*.json"):
        try:
            payload = json.loads(path.read_text(encoding="utf-8"))
        except Exception:
            continue

        if payload.get("task_id") != task_id:
            continue

        try:
            items.append(TaskEventRecord.from_dict(payload))
        except Exception:
            continue

    items.sort(key=lambda event: event.created_at)
    return items[-limit:]
