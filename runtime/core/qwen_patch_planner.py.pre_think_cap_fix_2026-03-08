#!/usr/bin/env python3
import argparse
import json
import os
import re
import sqlite3
from datetime import datetime
from pathlib import Path

try:
    import requests
except Exception:
    requests = None

WORKSPACE = Path("/home/rollan/.openclaw/workspace")
TASK_DB = WORKSPACE / "tasks" / "tasks.db"
RESULTS_DIR = WORKSPACE / "tasks" / "results"
ARTIFACT_ROOT = WORKSPACE / "artifacts" / "qwen_live"
STATE_PATH = WORKSPACE / "jarvis-v5" / "runtime" / "core" / "qwen_live_state.json"

MODEL_SERVER = os.getenv("QWEN_AGENT_MODEL_SERVER", "http://100.70.114.34:1234/v1").rstrip("/")
MODEL_NAME = os.getenv("QWEN_AGENT_MODEL", "qwen3.5-35b-a3b")
API_KEY = os.getenv("QWEN_AGENT_API_KEY", "lm-studio")


def now_iso() -> str:
    return datetime.now().isoformat()


def now_stamp() -> str:
    return datetime.now().strftime("%Y%m%d_%H%M%S")


def today_dir() -> Path:
    out = ARTIFACT_ROOT / datetime.now().strftime("%Y-%m-%d")
    out.mkdir(parents=True, exist_ok=True)
    return out


def strip_think(text: str) -> str:
    return re.sub(r"<think>.*?</think>\s*", "", text, flags=re.DOTALL).strip()


def read_state() -> dict:
    if not STATE_PATH.exists():
        return {
            "last_reviewed_task_id": None,
            "last_reviewed_at": None,
            "reviewed_task_ids": [],
        }
    return json.loads(STATE_PATH.read_text(encoding="utf-8"))


def read_task(task_id: int) -> dict:
    if not TASK_DB.exists():
        raise FileNotFoundError(f"Database not found: {TASK_DB}")

    conn = sqlite3.connect(str(TASK_DB))
    conn.row_factory = sqlite3.Row
    try:
        row = conn.execute("SELECT * FROM tasks WHERE id = ?", (task_id,)).fetchone()
        if row is None:
            raise RuntimeError(f"Task not found: {task_id}")
        return {col: row[col] for col in row.keys()}
    finally:
        conn.close()


def read_result(task_id: int, max_chars: int = 4000) -> dict:
    path = RESULTS_DIR / f"{task_id}.md"
    if not path.exists() or not path.is_file():
        return {
            "exists": False,
            "path": str(path),
            "content": "",
        }

    text = path.read_text(encoding="utf-8", errors="replace")
    return {
        "exists": True,
        "path": str(path.relative_to(WORKSPACE)),
        "content": text[:max_chars],
        "truncated": len(text) > max_chars,
        "total_chars": len(text),
    }


def extract_written_files(result_markdown: str) -> list[Path]:
    files: list[Path] = []
    for line in result_markdown.splitlines():
        line = line.strip()
        if not line.startswith("- /home/rollan/.openclaw/workspace/"):
            continue
        p = Path(line[2:].strip())
        try:
            p.resolve().relative_to(WORKSPACE)
            files.append(p)
        except Exception:
            continue
    return files[:6]


def read_text(path: Path, max_chars: int) -> str:
    if not path.exists() or not path.is_file():
        return f"[missing file] {path}"
    return path.read_text(encoding="utf-8", errors="replace")[:max_chars]


def call_model(prompt: str) -> str:
    if requests is None:
        raise RuntimeError("requests is not installed. Install with: pip install requests")
    headers = {
        "Authorization": f"Bearer {API_KEY}",
        "Content-Type": "application/json",
    }
    payload = {
        "model": MODEL_NAME,
        "messages": [
            {
                "role": "system",
                "content": (
                    "/no_think\n"
                    "You are an approval-gated patch planner for Jarvis v5.\n"
                    "You may propose the smallest safe patch, but you must not claim any code was changed.\n"
                    "Base everything only on the provided task, result artifact, and file contents.\n"
                    "Return concise markdown."
                ),
            },
            {"role": "user", "content": prompt},
        ],
        "temperature": 0.2,
    }

    r = requests.post(
        f"{MODEL_SERVER}/chat/completions",
        headers=headers,
        json=payload,
        timeout=300,
    )
    r.raise_for_status()
    data = r.json()
    return strip_think(data["choices"][0]["message"]["content"])


def build_prompt(task: dict, result_obj: dict, file_blobs: list[tuple[str, str]]) -> str:
    parts: list[str] = []

    parts.append("# Task")
    parts.append(json.dumps(task, indent=2, ensure_ascii=False))
    parts.append("")
    parts.append("# Result Artifact")
    parts.append(result_obj.get("content", ""))
    parts.append("")

    for rel, content in file_blobs:
        parts.append(f"# File: {rel}")
        parts.append(content)
        parts.append("")

    parts.append(
        "Write a markdown patch plan with these sections only:\n"
        "## Summary\n"
        "## Why This Patch Matters\n"
        "## Target Files\n"
        "## Smallest Safe Patch\n"
        "## Validation Checks\n"
        "## Risks\n"
        "## Approval Prompt\n\n"
        "Do not pretend the patch was applied. Keep it under 700 words."
    )

    return "\n".join(parts)


def write_artifact(task_id: int, title: str, report: str, state: dict) -> Path:
    out_dir = today_dir()
    out_path = out_dir / f"{now_stamp()}_task_{task_id}_patch_plan.md"

    text = [
        "# Qwen Patch Plan",
        "",
        f"- timestamp: {now_iso()}",
        f"- task_id: {task_id}",
        f"- title: {title}",
        f"- model: {MODEL_NAME}",
        "",
        "## Worker State",
        "```json",
        json.dumps(state, indent=2, ensure_ascii=False),
        "```",
        "",
        report,
        "",
    ]

    out_path.write_text("\n".join(text), encoding="utf-8")

    latest = out_dir / "latest_patch_plan.md"
    latest.write_text(out_path.read_text(encoding="utf-8"), encoding="utf-8")
    return out_path


def main() -> int:
    ap = argparse.ArgumentParser(
        description="Approval-gated patch planner for the latest reviewed task."
    )
    ap.add_argument(
        "--task-id",
        type=int,
        default=None,
        help="Explicit task id. Defaults to last_reviewed_task_id.",
    )
    ap.add_argument(
        "--max-file-chars",
        type=int,
        default=2000,
        help="Max chars per related file.",
    )
    ap.add_argument(
        "--json",
        action="store_true",
        help="Print machine-readable JSON.",
    )
    args = ap.parse_args()

    state = read_state()
    task_id = args.task_id or state.get("last_reviewed_task_id")
    if not task_id:
        raise RuntimeError("No task id provided and no last_reviewed_task_id found in state.")

    task = read_task(int(task_id))
    result_obj = read_result(int(task_id))
    file_paths = extract_written_files(result_obj.get("content", ""))

    file_blobs: list[tuple[str, str]] = []
    for p in file_paths:
        rel = str(p.relative_to(WORKSPACE))
        file_blobs.append((rel, read_text(p, args.max_file_chars)))

    prompt = build_prompt(task, result_obj, file_blobs)
    report = call_model(prompt)
    artifact = write_artifact(int(task_id), str(task.get("title", "")), report, state)

    payload = {
        "ok": True,
        "task_id": int(task_id),
        "title": task.get("title"),
        "artifact": str(artifact),
    }

    if args.json:
        print(json.dumps(payload, indent=2, ensure_ascii=False))
    else:
        print(f"Wrote: {artifact}")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
