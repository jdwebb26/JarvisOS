#!/usr/bin/env python3
from __future__ import annotations

import sys
from pathlib import Path
from typing import Optional


ROOT = Path(__file__).resolve().parents[2]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from runtime.core.task_runtime import append_task_event, load_task_record, save_task_record
from runtime.dashboard.rebuild_helpers import rebuild_all_outputs


def attach_artifact_to_task(
    *,
    task_id: str,
    artifact_id: str,
    artifact_type: str,
    title: str,
    actor: str,
    lane: str,
    root: Optional[Path] = None,
) -> dict:
    root_path = Path(root or ROOT).resolve()

    task = load_task_record(task_id, root=root_path)
    related = list(task.get("related_artifact_ids", []))

    already_linked = artifact_id in related
    if not already_linked:
        related.append(artifact_id)
        task["related_artifact_ids"] = related
        save_task_record(task, root=root_path)

    event = append_task_event(
        task_id=task_id,
        event_type="artifact_linked",
        actor=actor,
        lane=lane,
        details={
            "artifact_id": artifact_id,
            "artifact_type": artifact_type,
            "title": title,
            "already_linked": already_linked,
        },
        root=root_path,
    )

    rebuild_all_outputs(root_path)

    return {
        "task_id": task_id,
        "artifact_id": artifact_id,
        "artifact_type": artifact_type,
        "title": title,
        "already_linked": already_linked,
        "related_artifact_ids": task.get("related_artifact_ids", []),
        "event_id": event["event_id"],
    }
