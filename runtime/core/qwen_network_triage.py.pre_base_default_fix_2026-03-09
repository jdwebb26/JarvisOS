#!/usr/bin/env python3
import json, os, socket, subprocess, time
from urllib.parse import urlparse

BASE = os.getenv("QWEN_AGENT_MODEL_SERVER", "http://100.70.114.34:1234/v1").rstrip("/")
parsed = urlparse(BASE)
host = parsed.hostname or ""
port = parsed.port or (443 if parsed.scheme == "https" else 80)

def run(cmd):
    try:
        p = subprocess.run(cmd, capture_output=True, text=True, timeout=12)
        return {
            "cmd": cmd,
            "returncode": p.returncode,
            "stdout": p.stdout[-4000:],
            "stderr": p.stderr[-2000:],
        }
    except Exception as e:
        return {
            "cmd": cmd,
            "error": str(e),
        }

out = {
    "base": BASE,
    "host": host,
    "port": port,
}

try:
    out["getent_hosts"] = run(["getent", "hosts", host])
except Exception as e:
    out["getent_hosts"] = {"error": str(e)}

out["ip_route_get"] = run(["ip", "route", "get", host])
out["ping_1"] = run(["ping", "-c", "1", "-W", "2", host])
out["curl_models"] = run(["curl", "-sv", "--connect-timeout", "5", f"{BASE}/models"])

t0 = time.time()
try:
    sock = socket.create_connection((host, port), timeout=5)
    sock.close()
    out["tcp_connect"] = {"ok": True, "elapsed_sec": round(time.time() - t0, 3)}
except Exception as e:
    out["tcp_connect"] = {"ok": False, "elapsed_sec": round(time.time() - t0, 3), "error": str(e)}

print(json.dumps(out, indent=2))
