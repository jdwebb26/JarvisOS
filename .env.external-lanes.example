# ShadowBroker
JARVIS_SHADOWBROKER_BASE_URL=https://shadowbroker.example.internal
JARVIS_SHADOWBROKER_API_KEY=
JARVIS_SHADOWBROKER_TIMEOUT_SECONDS=5
JARVIS_SHADOWBROKER_VERIFY_SSL=true

# SearXNG
JARVIS_SEARXNG_URL=https://searxng.example.internal

# Hermes bridge
JARVIS_HERMES_BRIDGE_COMMAND=/opt/hermes/bin/hermes-bridge
JARVIS_HERMES_BRIDGE_CWD=/opt/hermes
JARVIS_HERMES_BRIDGE_TIMEOUT_SECONDS=15

# Autoresearch upstream
JARVIS_AUTORESEARCH_UPSTREAM_COMMAND=/opt/autoresearch/bin/autoresearch-upstream
JARVIS_AUTORESEARCH_UPSTREAM_CWD=/opt/autoresearch
JARVIS_AUTORESEARCH_UPSTREAM_TIMEOUT_SECONDS=30

# Local model proof lanes
JARVIS_UNSLOTH_TINY_MODEL=
JARVIS_DSPY_TINY_MODEL=
JARVIS_DSPY_API_BASE_URL=
JARVIS_DSPY_API_KEY=
