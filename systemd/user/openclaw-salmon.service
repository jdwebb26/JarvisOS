[Unit]
Description=OpenClaw Salmon Adapter — Fish backend scenario generation
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/rollan/.openclaw/workspace/jarvis-v5
ExecStart=/home/rollan/.openclaw/workspace/jarvis-v5/.venv/bin/python3 /home/rollan/.openclaw/workspace/jarvis-v5/workspace/quant_infra/salmon/adapter.py
EnvironmentFile=/home/rollan/.openclaw/secrets.env
StandardOutput=journal
StandardError=journal
SyslogIdentifier=openclaw-salmon
TimeoutStartSec=120
